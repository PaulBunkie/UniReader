<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp">

        <!-- Font Size -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:layout_marginTop="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Font Size"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvFontSizeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="18"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp" />
        </RelativeLayout>
        <com.google.android.material.slider.Slider
            android:id="@+id/sliderFontSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:stepSize="1"
            android:valueFrom="10"
            android:valueTo="32"
            app:labelBehavior="gone"
            app:trackColorActive="?attr/colorAccent"
            app:thumbColor="?attr/colorAccent"
            android:layout_marginTop="-4dp" />

        <!-- Paragraph Spacing -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:layout_marginTop="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paragraph Spacing"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvParagraphSpacingValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="1.0"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp" />
        </RelativeLayout>
        <com.google.android.material.slider.Slider
            android:id="@+id/sliderParagraphSpacing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:stepSize="0.1"
            android:valueFrom="0.0"
            android:valueTo="3.0"
            app:labelBehavior="gone"
            app:trackColorActive="?attr/colorAccent"
            app:thumbColor="?attr/colorAccent"
            android:layout_marginTop="-4dp" />

        <!-- Line Height -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:layout_marginTop="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Line Height"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvLineHeightValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="1.6"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp" />
        </RelativeLayout>
        <com.google.android.material.slider.Slider
            android:id="@+id/sliderLineHeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:stepSize="0.1"
            android:valueFrom="1.0"
            android:valueTo="3.0"
            app:labelBehavior="gone"
            app:trackColorActive="?attr/colorAccent"
            app:thumbColor="?attr/colorAccent"
            android:layout_marginTop="-4dp" />

        <!-- First Line Indent -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:layout_marginTop="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="First Line Indent"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvFirstLineIndentValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="0.0"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp" />
        </RelativeLayout>
        <com.google.android.material.slider.Slider
            android:id="@+id/sliderFirstLineIndent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:stepSize="0.5"
            android:valueFrom="0.0"
            android:valueTo="5.0"
            app:labelBehavior="gone"
            app:trackColorActive="?attr/colorAccent"
            app:thumbColor="?attr/colorAccent"
            android:layout_marginTop="-4dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>